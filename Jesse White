        <tr>
          <td>Full-Stack Trade Company Template</td>
          <td>Full-Stack</td>
          <td><a href="https://github.com/jaewhite25/Full_Stack_Trade_company_template">GitHub</a></td>
          <td>Python, C#, React, FastAPI, Docker</td>
        </tr>
        <tr>
