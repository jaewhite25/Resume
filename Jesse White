<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Jesse White - Portfolio & Resume</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --main-bg: linear-gradient(135deg, #e0e0e0 0%, #f8f8f8 100%);
      --table-bg: #fff;
      --accent: #666;
      --header-bg: #333;
      --header-text: #fff;
      --row-hover: #f0f0f0;
      --border-radius: 12px;
      --shadow: 0 4px 24px rgba(0,0,0,0.08);
    }

    body {
      margin: 0;
      min-height: 100vh;
      background: var(--main-bg);
      font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding-bottom: 60px;
      overflow: hidden;
    }

    canvas#particles {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }

    h1 {
      margin-top: 40px;
      color: #222;
      font-size: 2.5rem;
      letter-spacing: 2px;
      text-align: center;
    }

    h2 {
      margin-top: 32px;
      color: #222;
      font-size: 1.8rem;
      letter-spacing: 1px;
      text-align: center;
    }

    .table-container {
      background: var(--table-bg);
      box-shadow: var(--shadow);
      border-radius: var(--border-radius);
      padding: 32px;
      margin: 32px 0;
      min-width: 320px;
      max-width: 800px;
      width: 90vw;
      position: relative;
      z-index: 1;
    }

    table {
      border-collapse: separate;
      border-spacing: 0;
      width: 100%;
      font-size: 1.05rem;
      border-radius: var(--border-radius);
      overflow: hidden;
      box-shadow: 0 0 0 1px #ccc;
    }

    th, td {
      padding: 14px 20px;
      text-align: left;
      transition: background .25s, color .24s;
    }

    th {
      background: var(--header-bg);
      color: var(--header-text);
      font-weight: 600;
      text-shadow: none;
      position: sticky;
      top: 0;
      z-index: 2;
    }

    tbody tr:hover {
      background: var(--row-hover);
      transform: scale(1.01);
      cursor: pointer;
    }

    td:first-child {
      border-left: 4px solid var(--accent);
      font-weight: 500;
    }

    td a {
      color: #333;
      text-decoration: none;
      font-weight: 600;
    }

    td a:hover {
      text-decoration: underline;
    }

    @media (max-width: 600px) {
      .table-container { padding: 16px 0 8px 0; }
      th, td { padding: 10px 6px; font-size: 0.98rem; }
      h1 { font-size: 1.5rem; }
      h2 { font-size: 1.2rem; }
    }
  </style>
</head>
<body>
  <canvas id="particles"></canvas>

  <h1>Jae White - Portfolio & Resume</h1>

